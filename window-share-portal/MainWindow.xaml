<Window x:Class="MainWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Local Window Share"
        Icon="app.ico"
        Width="1050" Height="620"
        MinWidth="820" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        FontSize="13"
        Background="#0f0f0f"
        Foreground="#c9d1d9">

    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="BgBrush" Color="#0f0f0f"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#161b22"/>
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#21262d"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#30363d"/>
        <SolidColorBrush x:Key="TextBrush" Color="#c9d1d9"/>
        <SolidColorBrush x:Key="TextBrightBrush" Color="#e6edf3"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#8b949e"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#58a6ff"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#3fb950"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#f85149"/>

        <!-- Scrollbar Thumb -->
        <Style x:Key="DarkScrollThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder" CornerRadius="3" Background="#3a3a3a" Margin="1"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Scrollbar Line Button (invisible) -->
        <Style x:Key="DarkScrollLineButton" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" Height="0" Width="0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Scrollbar Page Button (track area) -->
        <Style x:Key="DarkScrollPageButton" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Vertical ScrollBar -->
        <ControlTemplate x:Key="DarkVerticalScrollBar" TargetType="ScrollBar">
            <Grid Width="8">
                <Border Background="#0f0f0f" CornerRadius="4" Opacity="0.3"/>
                <Track x:Name="PART_Track" IsDirectionReversed="True">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource DarkScrollPageButton}" Command="ScrollBar.PageUpCommand"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource DarkScrollThumb}"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource DarkScrollPageButton}" Command="ScrollBar.PageDownCommand"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <!-- Horizontal ScrollBar -->
        <ControlTemplate x:Key="DarkHorizontalScrollBar" TargetType="ScrollBar">
            <Grid Height="8">
                <Border Background="#0f0f0f" CornerRadius="4" Opacity="0.3"/>
                <Track x:Name="PART_Track" IsDirectionReversed="False">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource DarkScrollPageButton}" Command="ScrollBar.PageLeftCommand"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource DarkScrollThumb}"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource DarkScrollPageButton}" Command="ScrollBar.PageRightCommand"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Grid>
        </ControlTemplate>

        <!-- ScrollBar Style -->
        <Style TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="8"/>
                    <Setter Property="Height" Value="Auto"/>
                    <Setter Property="Template" Value="{StaticResource DarkVerticalScrollBar}"/>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="8"/>
                    <Setter Property="Template" Value="{StaticResource DarkHorizontalScrollBar}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#21262d"/>
            <Setter Property="Foreground" Value="#c9d1d9"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30363d"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#484f58"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1a1f27"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button -->
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#238636"/>
            <Setter Property="BorderBrush" Value="#2ea043"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2ea043"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1a7f37"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger Button -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#da3633"/>
            <Setter Property="BorderBrush" Value="#f85149"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#f85149"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#b62324"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#0d1117"/>
            <Setter Property="Foreground" Value="#c9d1d9"/>
            <Setter Property="CaretBrush" Value="#c9d1d9"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#58a6ff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PasswordBox -->
        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#0d1117"/>
            <Setter Property="Foreground" Value="#c9d1d9"/>
            <Setter Property="CaretBrush" Value="#c9d1d9"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#58a6ff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle Switch -->
        <Style x:Key="ToggleSwitch" TargetType="ToggleButton">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Track" CornerRadius="10" Background="#30363d"/>
                            <Border x:Name="Thumb" Width="14" Height="14" CornerRadius="7"
                                    Background="#8b949e" HorizontalAlignment="Left" Margin="3,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#238636"/>
                                <Setter TargetName="Thumb" Property="Background" Value="White"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListBox Item -->
        <Style x:Key="DarkListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#c9d1d9"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1c2128"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1f3a5f"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Access Item Template -->
        <DataTemplate x:Key="AccessItemTemplate">
            <StackPanel Orientation="Horizontal" Margin="0,1">
                <ToggleButton IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                              Style="{StaticResource ToggleSwitch}"
                              Click="OnAccessToggleClick" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding DisplayText}" Foreground="#c9d1d9"
                           FontFamily="Cascadia Mono, Consolas" FontSize="12"
                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                <TextBlock Text="{Binding CidrLabel}" Foreground="#484f58"
                           FontFamily="Cascadia Mono, Consolas" FontSize="11"
                           VerticalAlignment="Center" Margin="8,1,0,0"/>
            </StackPanel>
        </DataTemplate>

        <!-- Client Item Template -->
        <DataTemplate x:Key="ClientItemTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="130"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding RemoteAddress}" Foreground="#c9d1d9"
                           FontFamily="Cascadia Mono, Consolas" FontSize="12"/>
                <TextBlock Grid.Column="1" Text="{Binding EnvironmentLabel}" Foreground="#8b949e" FontSize="12"/>
                <TextBlock Grid.Column="2" Text="{Binding LastPath}" Foreground="#8b949e" FontSize="12"
                           TextTrimming="CharacterEllipsis"/>
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Ellipse Width="7" Height="7" Margin="0,0,4,0" VerticalAlignment="Center"
                             Fill="{Binding StatusColor}"/>
                    <TextBlock Text="{Binding StatusLabel}" Foreground="#8b949e" FontSize="12"/>
                </StackPanel>
                <TextBlock Grid.Column="4" Text="{Binding LastSeen}" Foreground="#8b949e"
                           FontFamily="Cascadia Mono, Consolas" FontSize="11"/>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Header -->
        <Border Grid.Row="0" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,0,0,1">
            <DockPanel Margin="20,12">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="&#x1F4CB; ログ" Style="{StaticResource ModernButton}"
                            Padding="12,7" Margin="0,0,8,0" Click="OnOpenLogWindow" FontSize="12"/>
                    <Button x:Name="ServerToggleButton" Style="{StaticResource PrimaryButton}"
                            Padding="16,7" Click="OnServerToggleClick">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="ServerToggleIcon" Text="&#x23FB;" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock x:Name="ServerToggleText" Text="開始"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Local Window Share" FontSize="16" FontWeight="SemiBold"
                               Foreground="#e6edf3" VerticalAlignment="Center"/>
                    <Border x:Name="StatusBadge" Margin="14,0,0,0" Padding="10,3"
                            CornerRadius="12" VerticalAlignment="Center">
                        <TextBlock x:Name="StatusBadgeText" FontSize="12" FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock x:Name="HeaderInfoText" Margin="12,0,0,0"
                               Foreground="#8b949e" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Row 1: Auth + Port cards -->
        <Grid Grid.Row="1" Margin="16,10,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Auth Card -->
            <Border Grid.Column="0" Background="#161b22" CornerRadius="8"
                    BorderBrush="#30363d" BorderThickness="1" Padding="14,10">
                <StackPanel>
                    <TextBlock Text="&#x1F512; &#x8A8D;&#x8A3C;" Foreground="#e6edf3" FontSize="13"
                               FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <PasswordBox x:Name="TokenPasswordBox" Width="260"
                                     Style="{StaticResource ModernPasswordBox}" PasswordChar="&#x2022;"/>
                        <TextBox x:Name="TokenTextBox" Width="260"
                                 Style="{StaticResource ModernTextBox}" Visibility="Collapsed"
                                 FontFamily="Cascadia Mono, Consolas" FontSize="12"/>
                        <Button x:Name="ShowTokenButton" Content="&#x1F441;" Margin="6,0,0,0"
                                Style="{StaticResource ModernButton}" Padding="8,6"
                                ToolTip="表示/非表示" Click="OnToggleTokenVisibility" FontSize="14"/>
                        <Button Content="生成" Margin="6,0,0,0" Style="{StaticResource ModernButton}"
                                Click="OnGenerateToken"/>
                        <Button Content="保存" Margin="6,0,0,0" Style="{StaticResource PrimaryButton}"
                                Click="OnSaveToken"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock x:Name="TokenSourceLabel" Foreground="#8b949e" FontSize="11"/>
                        <TextBlock Text="  |  " Foreground="#30363d" FontSize="11"/>
                        <TextBlock x:Name="SettingsPathLabel" Foreground="#8b949e" FontSize="11"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Port Card -->
            <Border Grid.Column="2" Background="#161b22" CornerRadius="8"
                    BorderBrush="#30363d" BorderThickness="1" Padding="14,10" MinWidth="200">
                <StackPanel>
                    <TextBlock Text="&#x1F310; &#x30DD;&#x30FC;&#x30C8;" Foreground="#e6edf3" FontSize="13"
                               FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="PortTextBox" Width="80"
                                 Style="{StaticResource ModernTextBox}"
                                 TextAlignment="Center" FontFamily="Cascadia Mono, Consolas"/>
                        <Button x:Name="ApplyPortButton" Content="適用" Margin="8,0,0,0"
                                Style="{StaticResource ModernButton}" Click="OnApplyPort"/>
                    </StackPanel>
                    <TextBlock x:Name="HostnameLabel" Foreground="#8b949e" FontSize="11" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Row 2: Network + Clients (side by side) -->
        <Grid Grid.Row="2" Margin="16,10,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Column: Network Access -->
            <Border Grid.Column="0" Background="#161b22" CornerRadius="8"
                    BorderBrush="#30363d" BorderThickness="1" Padding="14,10">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="&#x1F5A7; &#x30CD;&#x30C3;&#x30C8;&#x30EF;&#x30FC;&#x30AF;&#x30A2;&#x30AF;&#x30BB;&#x30B9;"
                                   Foreground="#e6edf3" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock Text="IPv4" Foreground="#484f58" FontSize="11"
                                   FontWeight="SemiBold" Margin="10,2,0,2"/>
                        <ListBox x:Name="Ipv4ListBox" Background="Transparent" BorderThickness="0"
                                 ItemTemplate="{StaticResource AccessItemTemplate}"
                                 ItemContainerStyle="{StaticResource DarkListBoxItem}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                 Tag="BindAddress"/>
                        <Border Height="1" Background="#30363d" Margin="10,6"/>
                        <TextBlock Text="IPv6" Foreground="#484f58" FontSize="11"
                                   FontWeight="SemiBold" Margin="10,2,0,2"/>
                        <ListBox x:Name="Ipv6ListBox" Background="Transparent" BorderThickness="0"
                                 ItemTemplate="{StaticResource AccessItemTemplate}"
                                 ItemContainerStyle="{StaticResource DarkListBoxItem}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                 Tag="BindAddress"/>

                        <!-- Manual Allowed Networks -->
                        <Border Height="1" Background="#30363d" Margin="10,8"/>
                        <TextBlock Text="&#x8A31;&#x53EF;&#x30CD;&#x30C3;&#x30C8;&#x30EF;&#x30FC;&#x30AF;&#x8FFD;&#x52A0;" Foreground="#484f58" FontSize="11"
                                   FontWeight="SemiBold" Margin="10,2,0,4"/>
                        <StackPanel Orientation="Horizontal" Margin="10,0,0,4">
                            <TextBox x:Name="AllowedNetworkInput" Width="200"
                                     Style="{StaticResource ModernTextBox}"
                                     FontFamily="Cascadia Mono, Consolas" FontSize="12"/>
                            <Button Content="&#x8FFD;&#x52A0;" Margin="6,0,0,0"
                                    Style="{StaticResource PrimaryButton}" Padding="10,5" FontSize="12"
                                    Click="OnAddAllowedNetwork"/>
                        </StackPanel>
                        <TextBlock Text="&#x4F8B;: 100.64.0.0/10 (Tailscale)" Foreground="#30363d" FontSize="10"
                                   Margin="10,0,0,2"/>
                        <ItemsControl x:Name="ManualNetworksList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="10,2,0,2">
                                        <Button Content="&#xD7;" Style="{StaticResource ModernButton}"
                                                Padding="5,1" FontSize="13" Foreground="#f85149"
                                                Click="OnRemoveAllowedNetwork" Tag="{Binding Cidr}"
                                                VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Cidr}" Foreground="#c9d1d9"
                                                   FontFamily="Cascadia Mono, Consolas" FontSize="12"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Right Column: Approval + Connected Clients -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" MaxHeight="260"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Client Approval -->
                <Border Grid.Row="0" Background="#161b22" CornerRadius="8"
                        BorderBrush="#30363d" BorderThickness="1" Padding="14,10">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,6">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#x5168;&#x8A31;&#x53EF;" Foreground="#8b949e" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ToggleButton x:Name="AllowAllToggle" Style="{StaticResource ToggleSwitch}"
                                              Click="OnAllowAllToggleClick"/>
                            </StackPanel>
                            <TextBlock Text="&#x1F6E1; &#x30AF;&#x30E9;&#x30A4;&#x30A2;&#x30F3;&#x30C8;&#x627F;&#x8A8D;"
                                       Foreground="#e6edf3" FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                        <TextBlock x:Name="ApprovalModeLabel" Foreground="#484f58" FontSize="11" Margin="0,0,0,4"/>

                        <!-- Pending Approvals -->
                        <ItemsControl x:Name="PendingApprovalsPanel">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1c1a00" CornerRadius="6"
                                            BorderBrush="#6e5c00" BorderThickness="1"
                                            Padding="10,6" Margin="0,2">
                                        <DockPanel>
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Button Content="&#x8A31;&#x53EF;" Style="{StaticResource PrimaryButton}"
                                                        Padding="10,3" FontSize="11"
                                                        Click="OnApprovePendingClient" Tag="{Binding IpAddress}"/>
                                                <Button Content="&#x62D2;&#x5426;" Style="{StaticResource DangerButton}"
                                                        Padding="10,3" FontSize="11" Margin="4,0,0,0"
                                                        Click="OnDenyPendingClient" Tag="{Binding IpAddress}"/>
                                            </StackPanel>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding IpAddress}" Foreground="#e3b341"
                                                           FontFamily="Cascadia Mono, Consolas" FontSize="12"/>
                                                <TextBlock Text="{Binding EnvironmentLabel}" Foreground="#8b949e"
                                                           FontSize="11"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Approved Clients -->
                        <ListBox x:Name="ApprovedClientsListBox" Background="Transparent" BorderThickness="0"
                                 ItemContainerStyle="{StaticResource DarkListBoxItem}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Content="&#xD7;"
                                                Style="{StaticResource ModernButton}"
                                                Padding="6,2" FontSize="14" Foreground="#f85149"
                                                Click="OnRevokeApprovedClient" Tag="{Binding IpAddress}"
                                                VerticalAlignment="Center"/>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding IpAddress}" Foreground="#c9d1d9"
                                                       FontFamily="Cascadia Mono, Consolas" FontSize="12"/>
                                            <TextBlock Text="{Binding Label}" Foreground="#484f58"
                                                       FontSize="11" Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </DockPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- Connected Clients -->
                <Border Grid.Row="2" Background="#161b22" CornerRadius="8"
                        BorderBrush="#30363d" BorderThickness="1" Padding="14,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,6">
                            <Button x:Name="DisconnectButton" DockPanel.Dock="Right"
                                    Content="&#x5207;&#x65AD;" Style="{StaticResource DangerButton}"
                                    Padding="10,4" IsEnabled="False" Click="OnDisconnectClient" FontSize="12"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4F1; &#x63A5;&#x7D9A;&#x30AF;&#x30E9;&#x30A4;&#x30A2;&#x30F3;&#x30C8;"
                                           Foreground="#e6edf3" FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="ClientCountLabel" Foreground="#8b949e" FontSize="12"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </DockPanel>

                        <Grid Grid.Row="1" Margin="10,0,10,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="130"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="IP" Foreground="#484f58" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="&#x74B0;&#x5883;" Foreground="#484f58" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="&#x30D1;&#x30B9;" Foreground="#484f58" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="3" Text="&#x72B6;&#x614B;" Foreground="#484f58" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="4" Text="&#x6700;&#x7D42;&#x30A2;&#x30AF;&#x30BB;&#x30B9;" Foreground="#484f58" FontSize="11" FontWeight="SemiBold"/>
                        </Grid>

                        <ListBox x:Name="ClientListBox" Grid.Row="2" Background="Transparent" BorderThickness="0"
                                 ItemTemplate="{StaticResource ClientItemTemplate}"
                                 ItemContainerStyle="{StaticResource DarkListBoxItem}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionChanged="OnClientSelectionChanged"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Row 3: Status Bar -->
        <Border Grid.Row="3" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,1,0,0"
                Margin="0,10,0,0" Padding="20,7">
            <TextBlock x:Name="StatusBarText" Foreground="#8b949e" FontSize="12"/>
        </Border>
    </Grid>
</Window>
